<div class="mct-widget" data-controller="mobile-calendar"
     data-mobile-calendar-approve-label-value="<%= t('actions.issue_calendar_entries.confirm_action.name') %>"
     data-mobile-calendar-cancel-entry-label-value="<%= t('mobile_calendar.cancel_entry_label') %>"
     data-mobile-calendar-edit-label-value="<%= t('avo.edit') %>"
     data-mobile-calendar-save-label-value="<%= t('avo.save') %>"
     data-mobile-calendar-notes-label-value="<%= t('mobile_calendar.notes_label') %>"
     data-mobile-calendar-notes-placeholder-value="<%= t('mobile_calendar.notes_placeholder') %>"
     data-mobile-calendar-cancel-confirm-title-value="<%= t('mobile_calendar.cancel_entry_confirm_title') %>"
     data-mobile-calendar-cancel-confirm-message-value="<%= t('mobile_calendar.cancel_entry_confirm_message') %>"
     data-mobile-calendar-cancel-confirm-yes-value="<%= t('mobile_calendar.cancel_entry_confirm_yes') %>"
     data-mobile-calendar-cancel-confirm-no-value="<%= t('mobile_calendar.cancel_entry_confirm_no') %>"
     data-mobile-calendar-resource-base-value="/resources/issue_calendar_entries">
  <%= render Avo::PanelComponent.new(name: '', display_breadcrumbs: false) do |c| %>
    <% c.body do %>
      <div class="mct-body">
        <div class="mct-container">
          <div class="mct-header">
            <button type="button" class="mct-burger" data-action="click->sidebar#toggleSidebarOnMobile" aria-label="Menü">☰</button>
            <button type="button" class="mct-nav" data-action="click->mobile-calendar#prevMonth" aria-label="Vorheriger Monat">‹</button>
            <h4 data-mobile-calendar-target="monthYear" class="mct-title"></h4>
            <button type="button" class="mct-nav" data-action="click->mobile-calendar#nextMonth" aria-label="Nächster Monat">›</button>
            <button type="button" class="mct-add-btn" data-action="click->mobile-calendar-entry-form#open" aria-label="Termin hinzufügen">+</button>
          </div>
          <div data-mobile-calendar-target="grid" class="mct-grid">
            <!-- Calendar days generated by JS -->
          </div>
        </div>

        <div class="mct-events">
          <div data-mobile-calendar-target="eventsTitle" class="mct-events-title"></div>
          <div data-mobile-calendar-target="eventsList" class="mct-events-list">
            <p class="mct-no-events">Keine Ereignisse</p>
          </div>
        </div>
      </div>

      <%# Sliding bottom sheet for new calendar entry %>
      <div class="mct-sheet-backdrop" data-mobile-calendar-entry-form-target="backdrop" data-action="click->mobile-calendar-entry-form#close"></div>
      <div class="mct-sheet" data-mobile-calendar-entry-form-target="sheet">
        <div class="mct-sheet-handle" data-action="click->mobile-calendar-entry-form#close"></div>
        <div class="mct-sheet-header">
          <h3 data-mobile-calendar-entry-form-target="sheetTitle">Neuer Termin</h3>
          <button type="button" class="mct-sheet-close" data-action="click->mobile-calendar-entry-form#close" aria-label="Schließen">×</button>
        </div>
        <form class="mct-sheet-form" data-mobile-calendar-entry-form-target="form" data-action="submit->mobile-calendar-entry-form#submit" id="mct-entry-form">
          <div class="mct-sheet-form-scroll">
            <div class="mct-form-group">
              <label>Kunde</label>
              <div class="mct-customer-field">
                <input type="hidden" data-mobile-calendar-entry-form-target="customerId" name="customer_id">
                <input type="text" data-mobile-calendar-entry-form-target="customerSearch" placeholder="Suchen oder tippen für Neu..."
                       autocomplete="off" data-action="input->mobile-calendar-entry-form#searchCustomer focus->mobile-calendar-entry-form#onCustomerSearchFocus">
                <div class="mct-customer-results" data-mobile-calendar-entry-form-target="customerResults"></div>
              </div>
            </div>
            <div class="mct-form-group">
              <label>Von</label>
              <div class="mct-datetime-row">
                <input type="date" data-mobile-calendar-entry-form-target="startDate" data-action="change->mobile-calendar-entry-form#startChanged" required>
                <input type="time" data-mobile-calendar-entry-form-target="startTime" data-action="change->mobile-calendar-entry-form#startChanged" required>
              </div>
            </div>
            <div class="mct-form-group">
              <label>Bis</label>
              <div class="mct-datetime-row">
                <input type="date" data-mobile-calendar-entry-form-target="endDate" required>
                <input type="time" data-mobile-calendar-entry-form-target="endTime" required>
              </div>
            </div>
            <div class="mct-form-group">
              <label>Notiz <span class="mct-optional">(optional)</span></label>
              <textarea data-mobile-calendar-entry-form-target="notes" data-action="input->mobile-calendar-entry-form#resizeNotes" rows="2" placeholder="Notizen..." class="mct-notes-autogrow"></textarea>
            </div>
            <div class="mct-form-errors" data-mobile-calendar-entry-form-target="errors"></div>
          </div>
          <div class="mct-sheet-actions">
            <button type="button" class="mct-btn-secondary" data-action="click->mobile-calendar-entry-form#close">Abbrechen</button>
            <button type="submit" class="mct-btn-primary">Speichern</button>
          </div>
        </form>
      </div>

      <%# New customer sheet - overlay spacer (grey area only) + sheet so form stays clickable %>
      <div class="mct-customer-overlay" data-mobile-calendar-entry-form-target="customerOverlay">
        <div class="mct-customer-overlay-spacer" data-action="click->mobile-calendar-entry-form#closeCustomerSheet"></div>
        <div class="mct-sheet mct-sheet-inner" data-mobile-calendar-entry-form-target="customerSheet">
            <div class="mct-sheet-handle" data-action="click->mobile-calendar-entry-form#closeCustomerSheet"></div>
          <div class="mct-sheet-header">
            <h3>Neuer Kunde</h3>
            <button type="button" class="mct-sheet-close" data-action="click->mobile-calendar-entry-form#closeCustomerSheet" aria-label="Schließen">×</button>
          </div>
          <form class="mct-sheet-form" data-mobile-calendar-entry-form-target="customerForm" data-action="submit->mobile-calendar-entry-form#submitCustomer" id="mct-customer-form">
            <div class="mct-sheet-form-scroll">
              <div class="mct-form-group">
                <label>Name *</label>
                <input type="text" data-mobile-calendar-entry-form-target="customerName" placeholder="Vorname Nachname" required>
              </div>
              <div class="mct-form-group">
                <label>Handynummer *</label>
                <input type="tel" data-mobile-calendar-entry-form-target="customerMobile" placeholder="z.B. 017612345678" required>
              </div>
              <div class="mct-form-group">
                <label>E-Mail <span class="mct-optional">(optional)</span></label>
                <input type="email" data-mobile-calendar-entry-form-target="customerEmail" placeholder="email@beispiel.de">
              </div>
              <div class="mct-form-errors" data-mobile-calendar-entry-form-target="customerErrors"></div>
            </div>
            <div class="mct-sheet-actions">
              <button type="button" class="mct-btn-secondary" data-action="click->mobile-calendar-entry-form#closeCustomerSheet">Abbrechen</button>
              <button type="submit" class="mct-btn-primary">Kunde anlegen</button>
            </div>
          </form>
        </div>
      </div>

      <%# Confirm modal for cancel entry (same style as desktop calendar_tool) %>
      <div class="mct-confirm-modal" data-mobile-calendar-target="confirmModal" aria-hidden="true">
        <div class="mct-confirm-modal-backdrop" data-action="click->mobile-calendar#closeCancelConfirm"></div>
        <div class="mct-confirm-modal-box">
          <h2 class="mct-confirm-modal-title" data-mobile-calendar-target="confirmModalTitle"></h2>
          <p class="mct-confirm-modal-message" data-mobile-calendar-target="confirmModalMessage"></p>
          <div class="mct-confirm-modal-actions">
            <button type="button" class="mct-confirm-modal-btn mct-confirm-modal-btn--cancel" data-action="click->mobile-calendar#closeCancelConfirm">
              <span data-mobile-calendar-target="confirmModalNoLabel"></span>
            </button>
            <button type="button" class="mct-confirm-modal-btn mct-confirm-modal-btn--ok" data-action="click->mobile-calendar#confirmCancelEntry">
              <span data-mobile-calendar-target="confirmModalYesLabel"></span>
            </button>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
